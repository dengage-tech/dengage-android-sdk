<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Row 1: LIVE indicator + period -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <ProgressBar
            android:id="@+id/den_pbLiveSportsIndicator"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:indeterminate="true"
            android:indeterminateTint="#FFCC0000"
            android:layout_marginEnd="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANLI"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#FFCC0000"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/den_tvLiveSportsPeriod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#FF888888"
            android:text="1. Yarı" />
    </LinearLayout>

    <!-- Row 2: Team1 | Score | Team2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/den_tvLiveSportsTeam1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#FF111111"
            android:gravity="start"
            android:maxLines="1"
            android:text="Galatasaray" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/den_tvLiveSportsScore1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="26sp"
                android:textColor="#FF111111"
                android:text="0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#FFAAAAAA"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text=":" />

            <TextView
                android:id="@+id/den_tvLiveSportsScore2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="26sp"
                android:textColor="#FF111111"
                android:text="0" />
        </LinearLayout>

        <TextView
            android:id="@+id/den_tvLiveSportsTeam2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#FF111111"
            android:gravity="end"
            android:maxLines="1"
            android:text="Fenerbahçe" />
    </LinearLayout>

    <!-- Row 3: Match time badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/den_tvLiveSportsTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:background="#FFCC0000"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="45'" />
    </LinearLayout>

</LinearLayout>
